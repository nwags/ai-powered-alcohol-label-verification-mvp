APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
ENABLE_PREPROCESSING=true
ENABLE_VISUALIZATION=true
ENABLE_DIAGNOSTICS_UI=true
ENABLE_OCR=true
OCR_USE_GPU=false
OCR_REQUIRE_LOCAL_MODELS=true
OCR_MODEL_SOURCE=local
OCR_MODEL_ROOT=/app/data/models/paddleocr
OCR_DET_MODEL_DIR=
OCR_REC_MODEL_DIR=
OCR_CLS_MODEL_DIR=
OCR_MAX_DIMENSION=2200
OCR_MAX_VARIANTS=3
OCR_ENABLE_DESKEW=false
STORAGE_DIR=/app/runtime
SAMPLE_DATA_DIR=/app/data
COVERAGE_DIR=/app/runtime/coverage
MAX_UPLOAD_BYTES=10485760
BATCH_MAX_RECORDS=200
BATCH_MAX_IMAGES=500
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
